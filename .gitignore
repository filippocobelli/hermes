# Raw acquired satellite imagery — never commit to git (Foundation Data Principles:
# datasets are versioned separately from code, and raw imagery is large/re-downloadable).
software/data/**/*.tif
software/data/**/*.jp2
software/data/case_001_verification/
software/data/case_001_geometry_check/

# Processed/derived tabular outputs (CSV, GeoJSON, JSON) ARE tracked — small,
# reproducible-but-costly-to-regenerate, and versioning them is explicitly
# required by foundation/FOUNDATION.md Data Principles ("version processed
# datasets").

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# OS
.DS_Store
